---
import { themeTemplates } from 'virtual:theme-templates';
import { createContext } from '@/lib/context';
import { preparePageData, preparePostData } from '@/lib/page-data';
import { buildPermalink, getRedirectPathIfDifferent } from '@/lib/content';

const { cid } = Astro.params;
const cidNum = parseInt(cid || '0', 10);
if (!cidNum) return Astro.redirect('/');

const ctx = await createContext(Astro.locals, Astro.request);

// If it's a page, the data layer will handle the redirect via contentRow.type check
// But we still need to handle the page redirect at the route level
const { db, options } = ctx;
import { eq } from 'drizzle-orm';
import { schema } from '@/db';

const contentRow = await db.query.contents.findFirst({
  where: eq(schema.contents.cid, cidNum),
});

if (!contentRow) return new Response('Not Found', { status: 404 });

const suppliedPassword = Astro.url.searchParams.get('password');
let result;
let Component;

// If it's a page, redirect to its configured page route unless that route is this URL.
if (contentRow.type === 'page') {
  const pageUrl = buildPermalink(
    { cid: contentRow.cid, slug: contentRow.slug, type: contentRow.type, created: contentRow.created },
    ctx.urls.siteUrl,
    undefined,
    options.pagePattern as string | undefined,
  );
  const redirectPath = getRedirectPathIfDifferent(Astro.request.url, pageUrl);
  if (redirectPath) return Astro.redirect(redirectPath);

  result = await preparePageData(ctx, contentRow.slug || String(contentRow.cid), Astro.request.url, suppliedPassword);
  if (result instanceof Response) return result;

  const activeTheme = options.theme || 'typecho-theme-minimal';
  const templates = themeTemplates[activeTheme] ?? {};
  const defaultTemplates = themeTemplates['typecho-theme-minimal']!;
  Component = templates.Page ?? defaultTemplates.Page!;
} else {
  result = await preparePostData(ctx, cidNum, Astro.request.url, suppliedPassword);
  if (result instanceof Response) return result;

  const activeTheme = options.theme || 'typecho-theme-minimal';
  const templates = themeTemplates[activeTheme] ?? {};
  const defaultTemplates = themeTemplates['typecho-theme-minimal']!;
  Component = templates.Post ?? defaultTemplates.Post!;
}
---
<Component {...result} />
