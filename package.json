{
  "name": "typecho",
  "type": "module",
  "version": "0.1.0",
  "description": "Typecho blog rewrite with Astro + Cloudflare Workers + D1",
  "exports": {
    "./plugin-sdk": "./src/lib/plugin-sdk.ts",
    "./db": "./src/db/index.ts"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "deploy": "pnpm build && wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "db:generate": "drizzle-kit generate",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "tsx scripts/migrate.ts",
    "db:migrate:local": "tsx scripts/migrate.ts --target local",
    "db:migrate:cloudflare": "tsx scripts/migrate.ts --target cloudflare",
    "db:migrate:dry-run": "tsx scripts/migrate.ts --dry-run",
    "reset-password": "tsx scripts/reset-password.ts --target local",
    "reset-password:cloudflare": "tsx scripts/reset-password.ts --target cloudflare"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.5.0",
    "astro": "^6.3.1",
    "drizzle-orm": "^0.45.2",
    "marked": "^18.0.3",
    "sanitize-html": "^2.17.3",
    "typecho-plugin-scribe": "file:src/plugins/typecho-plugin-scribe",
    "typecho-plugin-akismet": "file:src/plugins/typecho-plugin-akismet",
    "typecho-plugin-antispam": "file:src/plugins/typecho-plugin-antispam",
    "typecho-plugin-captcha": "file:src/plugins/typecho-plugin-captcha",
    "typecho-plugin-turnstile": "file:src/plugins/typecho-plugin-turnstile",
    "typecho-plugin-wechat-publisher": "file:src/plugins/typecho-plugin-wechat-publisher",
    "typecho-plugin-webdav": "file:src/plugins/typecho-plugin-webdav",
    "typecho-theme-minimal": "file:src/themes/typecho-theme-minimal"
  },
  "devDependencies": {
    "@libsql/client": "^0.17.3",
    "@types/sanitize-html": "^2.16.1",
    "@vitest/coverage-v8": "^4.1.6",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6",
    "wrangler": "^4.90.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "libsql",
      "sharp",
      "workerd"
    ],
    "allowedDeprecatedVersions": {
      "@esbuild-kit/core-utils": "3.3.2",
      "@esbuild-kit/esm-loader": "2.6.5",
      "@ungap/structured-clone": "1.3.0"
    }
  }
}
