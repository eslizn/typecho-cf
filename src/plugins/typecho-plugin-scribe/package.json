{
  "name": "typecho-plugin-scribe",
  "version": "1.0.0",
  "description": "AI writing assistant for Typecho-CF posts and pages",
  "keywords": ["typecho", "plugin", "ai", "writer"],
  "author": "eslizn",
  "license": "MIT",
  "type": "module",
  "main": "index.ts",
  "typecho": {
    "plugin": {
      "id": "typecho-plugin-scribe",
      "name": "Scribe",
      "description": "接入 OpenAI 兼容 LLM，在编辑器中生成、润色和纠错正文",
      "author": "eslizn",
      "authorUrl": "https://eslizn.com",
      "version": "1.0.0",
      "homepage": "https://github.com/eslizn/typecho-cf/tree/master/src/plugins/typecho-plugin-scribe",
      "license": "MIT",
      "tags": ["ai", "writer", "llm", "content"],
      "config": {
        "endpoint": {
          "type": "text",
          "label": "接口地址",
          "default": "https://open.bigmodel.cn/api/paas/v4/",
          "description": "OpenAI 兼容 Base URL，生成时自动追加 /chat/completions，保存时通过 /models 校验"
        },
        "apiKey": {
          "type": "password",
          "label": "API Key",
          "default": ""
        },
        "model": {
          "type": "text",
          "label": "模型名称",
          "default": "glm-4.7-flash",
          "description": "填写你的 LLM 服务商提供的模型 ID"
        },
        "temperature": {
          "type": "text",
          "label": "Temperature",
          "default": "0.7"
        },
        "maxTokens": {
          "type": "text",
          "label": "最大输出 Token",
          "default": "32000"
        },
        "stylePostCount": {
          "type": "text",
          "label": "风格参考文章数",
          "default": "5",
          "description": "生成、润色和纠错时读取最近 N 篇已发布文章作为作者风格样本，填写 0 可关闭"
        },
        "outputLanguage": {
          "type": "select",
          "label": "输出语言",
          "default": "auto",
          "options": {
            "auto": "自动判断",
            "zh-CN": "简体中文",
            "zh-TW": "繁体中文",
            "en": "English",
            "ja": "日本語",
            "ko": "한국어"
          },
          "description": "自动模式会优先沿用标题、正文和风格样本的主要语言"
        },
        "targetAudience": {
          "type": "text",
          "label": "目标读者",
          "default": "",
          "description": "可选，例如：后端工程师、个人博客读者、产品经理；留空时由模型根据历史文章推断"
        },
        "lengthPreset": {
          "type": "select",
          "label": "篇幅策略",
          "default": "balanced",
          "options": {
            "concise": "偏短",
            "balanced": "标准",
            "detailed": "深入"
          }
        },
        "factPolicy": {
          "type": "select",
          "label": "事实策略",
          "default": "conservative",
          "options": {
            "conservative": "保守，不确定不写死",
            "assumptive": "允许低风险常识推断"
          },
          "description": "保守模式会要求模型避免把上下文中没有的具体事实写成确定结论"
        },
        "userPrompt": {
          "type": "textarea",
          "label": "User Prompt",
          "default": "",
          "description": "可选的额外写作要求，会随标题、正文和风格样本一起发送给 LLM"
        },
        "includeBodyAssets": {
          "type": "select",
          "label": "发送正文图片和附件",
          "default": "0",
          "options": {
            "0": "关闭",
            "1": "开启"
          },
          "description": "开启后会提取正文中的图片、链接和当前内容附件；图片会尽量按 OpenAI image_url 发送，其他附件以链接和元数据发送"
        }
      }
    }
  }
}
