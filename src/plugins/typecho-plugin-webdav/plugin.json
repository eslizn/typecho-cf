{
  "id": "typecho-plugin-webdav",
  "name": "WebDAV",
  "description": "基于当前站点用户系统，通过 WebDAV 协议访问多个 S3/R2 后端存储挂载。",
  "author": "eslizn",
  "authorUrl": "https://eslizn.com",
  "version": "1.0.0",
  "homepage": "https://github.com/eslizn/typecho-cf",
  "license": "MIT",
  "tags": ["webdav", "storage", "s3", "r2"],
  "config": {
    "routePath": {
      "type": "text",
      "label": "入口路由路径",
      "default": "/webdav",
      "description": "WebDAV 入口路径，例如 /webdav。保存后通过该路径访问挂载的存储。"
    },
    "failBanEnabled": {
      "type": "select",
      "label": "登录失败封禁",
      "default": "true",
      "options": {
        "true": "启用",
        "false": "禁用"
      },
      "description": "启用后按客户端 IP 统计 WebDAV Basic Auth 失败次数。"
    },
    "failBanMaxFailures": {
      "type": "text",
      "label": "失败次数阈值",
      "default": "5",
      "description": "在统计窗口内达到该失败次数后封禁 IP。"
    },
    "failBanWindowSeconds": {
      "type": "text",
      "label": "统计窗口秒数",
      "default": "300",
      "description": "只统计该时间窗口内的连续失败。"
    },
    "failBanSeconds": {
      "type": "text",
      "label": "封禁秒数",
      "default": "900",
      "description": "触发阈值后的封禁持续时间。"
    },
    "mounts": {
      "type": "repeatable",
      "label": "后端存储挂载",
      "default": [
        {
          "mount": "",
          "provider": "r2",
          "bindingName": "BUCKET",
          "prefix": "",
          "endpoint": "",
          "bucket": "",
          "region": "us-east-1",
          "accessKeyId": "",
          "secretAccessKey": "",
          "pathStyle": "true"
        }
      ],
      "description": "每个挂载会作为入口根目录下的一级目录；挂载目录留空或填写 / 时会直接挂载入口根目录，且不能与其他挂载共存。prefix 可用于限制到桶内子目录。",
      "itemFields": {
        "mount": {
          "type": "text",
          "label": "挂载目录",
          "default": "",
          "description": "入口根目录下的一级目录名，例如 /webdav/media；留空或填写 / 表示挂载到 /webdav 根目录。"
        },
        "provider": {
          "type": "select",
          "label": "存储类型",
          "default": "r2",
          "options": {
            "r2": "Cloudflare R2",
            "s3": "Amazon S3 兼容"
          }
        },
        "bindingName": {
          "type": "select",
          "label": "R2 绑定",
          "default": "BUCKET",
          "optionsSource": "r2Bindings",
          "description": "选择 wrangler.toml 中 [[r2_buckets]] 声明的 binding。",
          "showWhen": {
            "field": "provider",
            "value": "r2"
          }
        },
        "endpoint": {
          "type": "text",
          "label": "Endpoint",
          "default": "",
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        },
        "bucket": {
          "type": "text",
          "label": "Bucket",
          "default": "",
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        },
        "region": {
          "type": "text",
          "label": "Region",
          "default": "us-east-1",
          "description": "S3 区域，例如 us-east-1。",
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        },
        "accessKeyId": {
          "type": "text",
          "label": "Access Key ID",
          "default": "",
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        },
        "secretAccessKey": {
          "type": "password",
          "label": "Secret Access Key",
          "default": "",
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        },
        "prefix": {
          "type": "text",
          "label": "桶内前缀",
          "default": "",
          "description": "可选。填写后 WebDAV 只能访问该前缀下的对象。"
        },
        "pathStyle": {
          "type": "select",
          "label": "路径风格",
          "default": "true",
          "options": {
            "true": "Path-style（推荐 R2）",
            "false": "Virtual-hosted-style"
          },
          "showWhen": {
            "field": "provider",
            "value": "s3"
          }
        }
      }
    }
  }
}
